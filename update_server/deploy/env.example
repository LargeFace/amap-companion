# Copy this file to update_server/.env and replace the placeholders.

HOST=0.0.0.0
PORT=8787
PUBLIC_BASE_URL=https://amap-companion.zuoqirun.top
AUTO_SYNC=1
SYNC_INTERVAL_MS=300000

GITHUB_REPO=zuo-qirun/amap-companion
# GITHUB_TOKEN=ghp_xxx
RELEASE_TAG=latest
ASSET_PATTERN=\\.apk$

# Enables the one-time initial registration form while no admin_users.json exists.
# The submitted username and password must exactly match these values.
# Remove both lines after initial registration and restart the service.
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-long-random-password
